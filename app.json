    },
    "OWNER_NUMBER": {
      "description": "Owner phone number (without +)",
      "value": "255650583044",
      "required": false
    },
    "CHANNEL_JID": {
      "description": "Newsletter/Channel JID for auto follow and react",
      "value": "120363424973782944@newsletter",
      "required": false
